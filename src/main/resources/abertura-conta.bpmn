<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.49.0">
  <bpmn:process id="abertura-conta" name="Abertura de Conta Bancária" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:laneSet>
      <bpmn:lane id="lane-analista" name="Analista">
        <bpmn:flowNodeRef>Gateway_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane-sistema" name="Sistema">
        <bpmn:flowNodeRef>Activity_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ClassificarIdade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_NotificarIdade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CalcularScore</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Age</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Score</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane-cliente" name="Cliente">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Início" />
    <bpmn:userTask id="Activity_1" name="Preencher Formulário Online" camunda:assignee="demo">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="nome" label="Nome Completo" type="string" />
          <camunda:formField id="cpf" label="CPF" type="string" />
          <camunda:formField id="idade" label="Idade" type="long" />
          <camunda:formField id="renda" label="Renda Comprovada" type="double" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_2" name="Validar Dados" camunda:class="com.exemplo.camundademo.delegate.ValidarDadosDelegate" />
    <bpmn:businessRuleTask id="Activity_ClassificarIdade" name="Classificar Idade" camunda:resultVariable="classificacaoIdade" camunda:decisionRef="classificarIdade" camunda:mapDecisionResult="singleResult">
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${processarClassificacaoIdadeDelegate}" event="end" />
      </bpmn:extensionElements>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_Age" name="Maior de idade?" default="Flow_Age_Nao">
      <bpmn:extensionElements />
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_NotificarIdade" name="Notificar Restrição de Idade" camunda:class="com.exemplo.camundademo.delegate.NotificarRejeicaoDelegate" />
    <bpmn:businessRuleTask id="Activity_CalcularScore" name="Calcular Score de Crédito" camunda:resultVariable="scoreCalculado" camunda:decisionRef="calcularScore" camunda:mapDecisionResult="singleResult">
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${verificarScoreDelegate}" event="end" />
      </bpmn:extensionElements>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_Score" name="Score ≥ 600?" default="Flow_Score_Reprovado">
      <bpmn:extensionElements />
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_5" name="Análise Manual" camunda:assignee="demo">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="aprovado" label="Cliente aprovado?" type="boolean" defaultValue="false" />
          <camunda:formField id="motivoRejeicao" label="Motivo da Rejeição (se reprovado)" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_2" name="Aprovado?" default="Flow_10" />
    <bpmn:serviceTask id="Activity_6" name="Notificar Rejeição" camunda:class="com.exemplo.camundademo.delegate.NotificarRejeicaoDelegate" />
    <bpmn:serviceTask id="Activity_7" name="Gerar Conta" camunda:class="com.exemplo.camundademo.delegate.GerarContaDelegate" />
    <bpmn:serviceTask id="Activity_8" name="Enviar Cartão" camunda:class="com.exemplo.camundademo.delegate.EnviarCartaoDelegate" />
    <bpmn:endEvent id="EndEvent_1" name="Fim" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Activity_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_1" targetRef="Activity_2" />
    <bpmn:sequenceFlow id="Flow_Classificar" sourceRef="Activity_2" targetRef="Activity_ClassificarIdade" />
    <bpmn:sequenceFlow id="Flow_117lof8" sourceRef="Activity_ClassificarIdade" targetRef="Gateway_Age" />
    <bpmn:sequenceFlow id="Flow_Age_Idoso" sourceRef="Gateway_Age" targetRef="Activity_5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${classificacaoIdade == "Idoso"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Age_Adulto" sourceRef="Gateway_Age" targetRef="Activity_CalcularScore">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${classificacaoIdade == "Adulto"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Age_Nao" sourceRef="Gateway_Age" targetRef="Activity_NotificarIdade" />
    <bpmn:sequenceFlow id="Flow_Age_Notificar" sourceRef="Activity_NotificarIdade" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_Score_Calc" sourceRef="Activity_CalcularScore" targetRef="Gateway_Score" />
    <bpmn:sequenceFlow id="Flow_Score_Aprovado" sourceRef="Gateway_Score" targetRef="Activity_7">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${scoreCalculado &gt;= 600}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Score_Reprovado" sourceRef="Gateway_Score" targetRef="Activity_5" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Activity_5" targetRef="Gateway_2" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Gateway_2" targetRef="Activity_7">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${aprovado}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_2" targetRef="Activity_6" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Activity_6" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Activity_7" targetRef="Activity_8" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Activity_8" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="abertura-conta">
      <bpmndi:BPMNShape id="lane-cliente_di" bpmnElement="lane-cliente" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1520" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane-sistema_di" bpmnElement="lane-sistema" isHorizontal="true">
        <dc:Bounds x="160" y="220" width="1520" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane-analista_di" bpmnElement="lane-analista" isHorizontal="true">
        <dc:Bounds x="160" y="520" width="1520" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="200" y="128" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="205" y="164" width="27" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1_di" bpmnElement="Activity_1">
        <dc:Bounds x="290" y="110" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_2_di" bpmnElement="Activity_2">
        <dc:Bounds x="290" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ClassificarIdade_di" bpmnElement="Activity_ClassificarIdade">
        <dc:Bounds x="450" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Age_di" bpmnElement="Gateway_Age" isMarkerVisible="true">
        <dc:Bounds x="615" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="600" y="279" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_NotificarIdade_di" bpmnElement="Activity_NotificarIdade">
        <dc:Bounds x="1130" y="430" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CalcularScore_di" bpmnElement="Activity_CalcularScore">
        <dc:Bounds x="740" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Score_di" bpmnElement="Gateway_Score" isMarkerVisible="true">
        <dc:Bounds x="905" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="890" y="279" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_2_di" bpmnElement="Gateway_2" isMarkerVisible="true">
        <dc:Bounds x="1025" y="595" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1023" y="655" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_6_di" bpmnElement="Activity_6">
        <dc:Bounds x="1290" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_7_di" bpmnElement="Activity_7">
        <dc:Bounds x="1180" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_8_di" bpmnElement="Activity_8">
        <dc:Bounds x="1360" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1532" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1540" y="282" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_5_di" bpmnElement="Activity_5">
        <dc:Bounds x="530" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="236" y="147" />
        <di:waypoint x="290" y="147" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="190" />
        <di:waypoint x="340" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Classificar_di" bpmnElement="Flow_Classificar">
        <di:waypoint x="390" y="320" />
        <di:waypoint x="450" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_117lof8_di" bpmnElement="Flow_117lof8">
        <di:waypoint x="550" y="320" />
        <di:waypoint x="615" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Age_Idoso_di" bpmnElement="Flow_Age_Idoso">
        <di:waypoint x="640" y="295" />
        <di:waypoint x="640" y="270" />
        <di:waypoint x="580" y="270" />
        <di:waypoint x="580" y="580" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Age_Adulto_di" bpmnElement="Flow_Age_Adulto">
        <di:waypoint x="665" y="320" />
        <di:waypoint x="740" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Age_Nao_di" bpmnElement="Flow_Age_Nao">
        <di:waypoint x="640" y="345" />
        <di:waypoint x="640" y="470" />
        <di:waypoint x="1130" y="470" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Age_Notificar_di" bpmnElement="Flow_Age_Notificar">
        <di:waypoint x="1250" y="470" />
        <di:waypoint x="1550" y="470" />
        <di:waypoint x="1550" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Score_Calc_di" bpmnElement="Flow_Score_Calc">
        <di:waypoint x="840" y="320" />
        <di:waypoint x="905" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Score_Aprovado_di" bpmnElement="Flow_Score_Aprovado">
        <di:waypoint x="955" y="320" />
        <di:waypoint x="1180" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Score_Reprovado_di" bpmnElement="Flow_Score_Reprovado">
        <di:waypoint x="930" y="345" />
        <di:waypoint x="930" y="590" />
        <di:waypoint x="630" y="590" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="630" y="620" />
        <di:waypoint x="1025" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1050" y="595" />
        <di:waypoint x="1050" y="250" />
        <di:waypoint x="1230" y="250" />
        <di:waypoint x="1230" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1075" y="620" />
        <di:waypoint x="1290" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1390" y="620" />
        <di:waypoint x="1550" y="620" />
        <di:waypoint x="1550" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1280" y="320" />
        <di:waypoint x="1360" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1460" y="320" />
        <di:waypoint x="1532" y="320" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
